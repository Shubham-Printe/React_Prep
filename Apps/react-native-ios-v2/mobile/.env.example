# Copy to ".env" in this folder. Use ONE of the backends (Groq is best for free demos).

# Free demo (recommended): https://console.groq.com/keys — same key for speech + note model
EXPO_PUBLIC_GROQ_API_KEY=

# Optional: richer errors when voice upload fails (URI tail, filename). Restart Expo after changing.
# EXPO_PUBLIC_VOICE_UPLOAD_DEBUG=1

# Paid / alternative: https://platform.openai.com/api-keys
# EXPO_PUBLIC_OPENAI_API_KEY=
